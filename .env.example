# ルート .env テンプレート（backend 用。frontend は frontend/.env.example）
# ローカル開発（in-memory・認証無効・同期worker）:
AUTH_DISABLED=1
# ローカル同期経路(core/tasks.py の httpx 直叩き)が OIDC 無しで 401 自爆しないよう必須。
# 本番では未設定(=False)のまま=worker OIDC 常に必須(fail-closed)。
WORKER_OIDC_DISABLED=1

# --- GCP（本番 / Step1b で設定） ---
# GCP_PROJECT=speak-score-xxxxx
# REGION=us-central1
# GCS_BUCKET=speak-score-uploads
# TASKS_QUEUE=speak-score-process
# WORKER_URL=https://speak-score-backend-xxxxx.run.app
# WORKER_SA=tasks-invoker@speak-score-xxxxx.iam.gserviceaccount.com
# WORKER_AUDIENCE=https://speak-score-backend-xxxxx.run.app

# --- Auth (Firebase) ---
# FIREBASE_PROJECT=speak-score-xxxxx
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099   # docker-compose ローカル時

# --- Firestore emulator（docker-compose ローカル時） ---
# FIRESTORE_EMULATOR_HOST=localhost:8081

# --- LLM / Whisper ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# WHISPER_API_KEY=
