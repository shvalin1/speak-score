# フロントエンド環境変数（Vite は VITE_ プレフィックスのみ公開）
# 加藤の開発はモックモードでOK（バックエンド不要）:
VITE_USE_MOCK=1

# 実APIに繋ぐとき:
# VITE_USE_MOCK=0
# VITE_API_BASE=/api            # 既定。Nginx/Vite proxy が backend へ転送
# VITE_PROXY_TARGET=http://localhost:8080  # Vite単体開発時のproxy先

# Firebase Auth（実認証を使うとき。モックモードでは不要）
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
